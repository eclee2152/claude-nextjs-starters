{
  "permissions": {
    "allow": [
      "Bash",
      "WebSearch",
      "WebFetch",
      "mcp__playwright",
      "Skill(nextjs-16)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "playwright"
  ],
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/slack-notify.js",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/slack-notify.js",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
